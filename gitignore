# =============================================================================
# CLI-Agent — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# CRITICAL — Never commit these
# -----------------------------------------------------------------------------
*.env
.env.*
!.env.example
secrets/
*.key
*.pem
*.p12
*.pfx

# Telemetry database (local data, not for version control)
telemetry.db
telemetry.db-shm
telemetry.db-wal

# Shadow clone working directories
.shadow_clones/
tmp/
/tmp/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.venv/
venv/
env/
ENV/
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# -----------------------------------------------------------------------------
# Podman / Container artifacts
# -----------------------------------------------------------------------------
*.tar
*.oci

# -----------------------------------------------------------------------------
# Kata Containers — local runtime state
# -----------------------------------------------------------------------------
/run/
/var/run/

# -----------------------------------------------------------------------------
# Ollama model cache (too large, referenced by name in docs)
# -----------------------------------------------------------------------------
*.gguf
*.ggml
models/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
agent_logs/

# -----------------------------------------------------------------------------
# OS artifacts
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# IDE
# -----------------------------------------------------------------------------
.vscode/settings.json
.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo

# -----------------------------------------------------------------------------
# GitHub Actions — local act runner cache
# -----------------------------------------------------------------------------
.act/
